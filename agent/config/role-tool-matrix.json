    "manager": {
      "read": true,
      "write": true,
      "exec": true,
      "media": true,
      "agent": true,
      "admin": false
    },
    "member": {
      "read": true,
      "write": true,
      "exec": true,
      "media": true,
      "agent": false,
      "admin": false
    },
    "cs": {
      "read": true,
      "write": false,
      "exec": false,
      "media": true,
      "agent": false,
      "admin": false
    },
    "viewer": {
      "read": true,
      "write": false,
      "exec": false,
      "media": false,
      "agent": false,
      "admin": false
    }
  },
  "high_risk_tools": {
    "_description": "高危工具在所有非 admin 角色下需要二次确认（human-approval.mjs）",
    "tools": ["exec", "shell", "write", "write_file", "edit", "edit_file"],
    "require_confirmation_for_roles": ["manager", "member"]
  }
