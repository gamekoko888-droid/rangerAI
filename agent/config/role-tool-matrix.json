    "write": ["write", "write_file", "file_write", "edit", "edit_file", "file_str_replace", "create_file", "prose"],
    "exec": ["exec", "shell"],
    "media": ["tts", "generate_image", "transcribe_audio", "speak_text", "analyze_image", "analyze_video", "analyze_audio", "analyze_document"],
    "agent": ["sessions", "subagents", "sessions_spawn", "sessions_send", "sessions_list", "cron", "message"],
