{
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "no-empty-function": "warn",
    "no-empty": ["warn", { "allowEmptyCatch": false }],
    "eqeqeq": ["error", "always"],
    "no-var": "error",
    "prefer-const": "warn",
    "no-throw-literal": "error",
    "no-eval": "error",
    "no-implied-eval": "error"
  },
  "ignorePatterns": ["node_modules/", "dist/", "*.bak", "backups/"]
}
