#!/bin/bash
# RangerAI pre-commit hook v3.0 — MODEL-GOVERNANCE v4.0 强制门控
# 
# 检查项:
#   1. .mjs 语法检查（L1）
#   2. 新增模块引用检查（规则九：禁止写了不用）
#   3. iter-verify 快照（规则十：L3 运行时验证基础）——WARN 不阻断
#   4. 禁止绕过验收的紧急提交检测
set -e

echo "[pre-commit] v3.0 governance hook"

STAGED=$(git diff --cached --name-only 2>/dev/null || true)
if [ -z "$STAGED" ]; then
  echo "[pre-commit] No staged files, skipping."
  exit 0
fi

ERRORS=0
WARNS=0
BASE="/opt/rangerai-agent"

# ── Gate 1: .mjs 语法检查 ──
echo "[pre-commit] Gate 1/3: Syntax check..."
while IFS= read -r file; do
  [ -z "$file" ] && continue
  case "$file" in
    *.mjs)
      if [ ! -f "$file" ]; then continue; fi
      if ! node --check "$file" 2>/dev/null; then
        echo "[pre-commit] ❌ SYNTAX ERROR: $file"
        ERRORS=$((ERRORS + 1))
      fi
      ;;
  esac
done <<< "$STAGED"

# ── Gate 2: 新增模块引用检查（规则九）──
echo "[pre-commit] Gate 2/3: Dead code check for new modules..."
while IFS= read -r file; do
  [ -z "$file" ] && continue
  case "$file" in
    worker/*.mjs|modules/*.mjs)
      # Only check newly created files (A = Added)
      status=$(git diff --cached --diff-filter=A --name-only "$file" 2>/dev/null)
      if [ -n "$status" ]; then
        name=$(basename "$file" .mjs)
        refs=$(grep -rn "from.*[./]${name}\.mjs\|import.*[./]${name}\.mjs\|require.*${name}" \
          "$BASE"/worker/*.mjs "$BASE"/modules/*.mjs "$BASE"/*.mjs 2>/dev/null \
          | grep -v "$(basename "$file"):" | grep -v '.bak' | grep -v '.test.mjs' | wc -l)
        if [ "$refs" -eq 0 ]; then
          echo "[pre-commit] ⚠️  WARN: New module '$name' has ZERO production references (规则九)"
          echo "[pre-commit]     If this module cannot be integrated this round, DO NOT commit it."
          WARNS=$((WARNS + 1))
        else
          echo "[pre-commit] ✅ New module '$name' has $refs reference(s)"
        fi
      fi
      ;;
  esac
done <<< "$STAGED"

# ── Gate 3: iter-verify 最近快照（WARN 不阻断）──
echo "[pre-commit] Gate 3/3: iter-verify snapshot..."
ITV_JSON=$(ls -t "$BASE/memory/iter-verify-R"*.json 2>/dev/null | head -1)
if [ -z "$ITV_JSON" ]; then
  echo "[pre-commit] ⚠️  WARN: No iter-verify snapshot found. Run: bash iter-verify.sh <round>"
  WARNS=$((WARNS + 1))
else
  ITV_AGE_MIN=$(( ($(date +%s) - $(stat -c %Y "$ITV_JSON" 2>/dev/null || echo 0)) / 60 ))
  if [ "$ITV_AGE_MIN" -gt 120 ]; then
    echo "[pre-commit] ⚠️  WARN: Last iter-verify is ${ITV_AGE_MIN}min old (>2h). Run: bash iter-verify.sh <round>"
    WARNS=$((WARNS + 1))
  else
    echo "[pre-commit] ✅ iter-verify snapshot: $(basename "$ITV_JSON") (${ITV_AGE_MIN}min ago)"
  fi
fi

# ── Summary ──
echo ""
if [ $ERRORS -gt 0 ]; then
  echo "[pre-commit] ❌ BLOCKED: $ERRORS error(s), $WARNS warning(s)"
  exit 1
elif [ $WARNS -gt 0 ]; then
  echo "[pre-commit] ⚠️  PASSED with $WARNS warning(s) — consider fixing before push"
else
  echo "[pre-commit] ✅ PASSED"
fi
exit 0
