          } else if (step.taskPhase === 'validation') {
            step.reviewPolicy = 'gpt_review';
          } else {
            step.reviewPolicy = step.critical ? 'gpt_review' : 'auto_pass';
          }
        }
        // Ensure last step always gets gpt_review
        if (step === plan.steps[plan.steps.length - 1]) {
