{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist-types",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "baseUrl": "."
  },
  "include": [
    "worker/lib/structured-logger.ts",
    "worker/lib/ttl-map.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist-types",
    "dist",
    ".bak*"
  ]
}
